# ---- Server ----
PORT=8080
APP_ENV=development

# ---- Database (Supabase / PostgreSQL) ----
# Use the connection pooler string (port 6543) in production.
DATABASE_URL=postgres://postgres:postgres@localhost:5432/pharmacy?sslmode=disable

# ---- JWT ----
JWT_SECRET=change_me_to_a_long_random_secret
JWT_ACCESS_TTL=60m
JWT_REFRESH_TTL=168h

# ---- CORS ----
# Comma-separated list of allowed origins (the Vercel domain in production).
CORS_ALLOWED_ORIGINS=http://localhost:3000

# ---- Bootstrap admin (created on first run if no users exist) ----
BOOTSTRAP_ADMIN_USERNAME=admin
BOOTSTRAP_ADMIN_PASSWORD=admin1234
BOOTSTRAP_ADMIN_NAME=System Administrator

# ---- Business settings ----
NEAR_EXPIRY_DAYS=180

# ---- LINE Messaging API (used in later phases) ----
LINE_CHANNEL_ACCESS_TOKEN=
